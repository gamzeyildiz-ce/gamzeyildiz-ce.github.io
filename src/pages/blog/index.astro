---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Blog" description={SITE_DESCRIPTION} />

    <style>
      main {
        max-width: 1000px;
        margin: 0 auto;
        padding: 3rem 2rem;
      }

      .hero {
        width: 100%;
        height: 450px;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      }

      .hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div class="hero">
        <img src="/blog.jpg" alt="Blog image" />
      </div>
    <p class="empty">
    No posts yet.
  </p>
    </main>

    <Footer />
  </body>
</html>